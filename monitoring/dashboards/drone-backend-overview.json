{
  "uid": "drone-backend-overview",
  "title": "Drone Backend — Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Backend",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "up{job=\"spring-backend\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "graphMode": "none", "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 2,
      "title": "Requêtes / s",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-backend\"}[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 3,
      "title": "Latence HTTP p95",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"spring-backend\"}[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 4,
      "title": "PostgreSQL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "pg_up", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "graphMode": "none", "colorMode": "background", "textMode": "value_and_name" }
    },

    {
      "id": 10,
      "title": "JVM Heap utilisée",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "jvm_memory_used_bytes{job=\"spring-backend\", area=\"heap\"}", "legendFormat": "{{id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "jvm_memory_max_bytes{job=\"spring-backend\", area=\"heap\"}", "legendFormat": "max {{id}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 11,
      "title": "CPU process (backend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage{job=\"spring-backend\"} * 100", "legendFormat": "CPU %", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    },
    {
      "id": 12,
      "title": "Threads JVM actifs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "jvm_threads_live_threads{job=\"spring-backend\"}", "legendFormat": "threads vivants", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },

    {
      "id": 20,
      "title": "Requêtes HTTP par statut",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"spring-backend\"}[1m]))", "legendFormat": "{{status}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 21,
      "title": "Latence HTTP (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"spring-backend\"}[5m])) by (le))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"spring-backend\"}[5m])) by (le))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"spring-backend\"}[5m])) by (le))", "legendFormat": "p99", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 30,
      "title": "Connexions PostgreSQL actives",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "pg_stat_database_numbackends{datname=\"dronedb\"}", "legendFormat": "connexions actives", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 31,
      "title": "Taille de la base de données",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "pg_database_size_bytes{datname=\"dronedb\"}", "legendFormat": "taille DB", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },

    {
      "id": 40,
      "title": "CPU par conteneur",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"drone-.*\"}[1m])) * 100", "legendFormat": "{{name}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 41,
      "title": "Mémoire par conteneur",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "container_memory_usage_bytes{name=~\"drone-.*\"}", "legendFormat": "{{name}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },

    {
      "id": 50,
      "title": "État des cibles Prometheus",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "up", "legendFormat": "{{job}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 1 } }
    }
  ]
}
